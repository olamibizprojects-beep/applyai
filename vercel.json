{
  "framework": "nextjs",
  "functions": {
    "app/api/generate/route.ts": { "maxDuration": 60 },
    "app/api/stripe/webhook/route.ts": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [],
  "redirects": []
}
